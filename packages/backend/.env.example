NODE_ENV=production
PORT=3000

# Public URLs
FRONTEND_URL=https://seu-front.vercel.app
API_PUBLIC_URL=https://api.seudominio.com

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Redis / Valkey
REDIS_URL=rediss://default:PASSWORD@HOST:6379

# API process should not process queues in production.
PROCESS_QUEUES=false
RUN_SCHEDULER=false
JSON_BODY_LIMIT=2mb
MAX_UPLOAD_BYTES=1500000
UPLOADS_PUBLIC_URL=https://api.seudominio.com/uploads

# Business rules
SERVICE_CITY=Rondon
SERVICE_STATE=PR
PLATFORM_DELIVERY_FEE=5
PLATFORM_COMMISSION_RATE=0
DELIVERER_PAY_PER_DELIVERY=0

# Worker process should use:
# PROCESS_QUEUES=true
# PIX_SWEEP_INTERVAL_MS=60000

# Security
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
ENCRYPTION_KEY=32-caracteres-minimo-ou-chave-base64
DELIVERY_RESPONSE_SECRET=troque-por-outro-segredo-longo-e-aleatorio

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_CLIENT_ID=
MERCADO_PAGO_CLIENT_SECRET=
MERCADO_PAGO_REDIRECT_URI=https://api.seudominio.com/api/payments/oauth/callback
MERCADO_PAGO_WEBHOOK_SECRET=troque-por-um-segredo-de-webhook
MOCK_PAYMENT=false

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
