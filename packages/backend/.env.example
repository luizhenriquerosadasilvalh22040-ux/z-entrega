PORT=3000
MONGODB_URI=mongodb://localhost:27017/trazpraca?replicaSet=rs0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
JWT_SECRET=trazpraca-jwt-secret-very-secure-key-12345
JWT_EXPIRATION=24h
REFRESH_EXPIRATION_DAYS=7
ENCRYPTION_SECRET=trazpraca-secret-key-default-12345
LOG_LEVEL=info

# Configurações do WhatsApp Business API (Meta Cloud API)
# Obtenha em: developers.facebook.com > Seu App > WhatsApp > Configuração de API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Token secreto que VOCÊ define — use o mesmo valor no painel da Meta ao cadastrar o webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Configurações do Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_CLIENT_ID=
MERCADO_PAGO_CLIENT_SECRET=
MERCADO_PAGO_REDIRECT_URI=http://localhost:3000/api/payments/oauth/callback
MOCK_PAYMENT=true

# Credenciais de Admin Padrão (Seed)
ADMIN_EMAIL=admin@trazpraca.com
ADMIN_PASSWORD=admin123

# Configurações de Teste de OTP
TESTING_PHONE=44999998888
TESTING_OTP=1234

# URL(s) do frontend separadas por vírgula para liberação de CORS
FRONTEND_URL=


