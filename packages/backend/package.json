{
  "name": "traz-pra-ca-backend",
  "version": "1.0.0",
  "description": "Backend for Traz Pra Ca Delivery",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
