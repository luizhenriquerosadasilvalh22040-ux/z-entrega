datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum MerchantSubscriptionStatus {
  INACTIVE
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  ACCEPTED
  PREPARING
  READY
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  RECEIVED
  REJECTED
  CANCELLED
  OVERDUE
  REFUND_PENDING
  REFUNDED
  REFUND_FAILED
}

enum DelivererResponseStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DelivererWorkStatus {
  AVAILABLE
  COLLECTING
  DELIVERING
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum PaymentWebhookEventStatus {
  PROCESSING
  PROCESSED
  SKIPPED
  FAILED
}

enum PaymentRefundStatus {
  PENDING
  approved
  rejected
  cancelled
  REFUND_FAILED
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED
}

enum DeliveryAssignmentStatus {
  PENDING
  ACCEPTED
  REJECTED
  TIMED_OUT
  CANCELLED
}

enum AuditActorType {
  customer
  merchant
  deliverer
  admin
  system
}

enum WhatsAppTemplateType {
  CUSTOMER_OTP
  ORDER_CREATED
  STORE_ORDER_CREATED
  PAYMENT_APPROVED
  ORDER_ACCEPTED
  ORDER_CANCELLED
  ORDER_READY
  DELIVERY_REQUEST
  DELIVERY_ACCEPTED
}

model Merchant {
  id                String    @id @default(uuid()) @db.Uuid
  name              String
  email             String    @unique
  passwordHash      String    @map("password_hash")
  cnpj              String    @unique // Criptografado
  phone             String
  category          String?   // 'Comida', 'Farmácia', 'Construção', 'Geral'
  openTime          String    @default("08:00") @map("open_time")
  closeTime         String    @default("22:00") @map("close_time")
  paymentMethods    String[]  @map("payment_methods")
  street            String
  number            String
  neighborhood      String
  city              String
  state             String    @default("PR")
  zipCode           String    @map("zip_code")
  latitude          Float?
  longitude         Float?
  isVerified        Boolean   @default(false) @map("is_verified")
  isActive          Boolean   @default(true) @map("is_active")
  isForceClosed     Boolean   @default(false) @map("is_force_closed")
  logoImage         String?   @map("logo_image")
  coverImage        String?   @map("cover_image")
  subscriptionPrice Float?    @map("subscription_price")
  mpAccessToken     String?   @map("mp_access_token")
  mpRefreshToken    String?   @map("mp_refresh_token")
  mpUserId          String?   @map("mp_user_id")
  mpSubscriptionId  String?   @map("mp_subscription_id")
  subscriptionStatus MerchantSubscriptionStatus? @default(INACTIVE) @map("subscription_status")
  passwordResetToken  String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  termsAcceptedAt DateTime? @map("terms_accepted_at")
  privacyAcceptedAt DateTime? @map("privacy_accepted_at")
  marketingConsent Boolean @default(false) @map("marketing_consent")
  timezone          String    @default("America/Sao_Paulo")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  products          Product[]
  orders            Order[]
  promotions        Promotion[]
  reviews           Review[]
  coupons           Coupon[]
  auditLogs         AuditLog[]

  @@index([isActive, subscriptionStatus])
  @@index([city, category])
  @@map("merchants")
}

model Customer {
  id              String            @id @default(uuid()) @db.Uuid
  name            String
  email           String?           @unique
  passwordHash    String?           @map("password_hash")
  cpf             String?           @unique
  phone           String            @unique
  isPhoneVerified Boolean           @default(false) @map("is_phone_verified")
  verificationCode String?          @map("verification_code")
  verificationCodeExpires DateTime? @map("verification_code_expires")
  mpCustomerId    String?           @map("mp_customer_id")
  isActive        Boolean           @default(true) @map("is_active")
  termsAcceptedAt DateTime?         @map("terms_accepted_at")
  privacyAcceptedAt DateTime?       @map("privacy_accepted_at")
  marketingConsent Boolean          @default(false) @map("marketing_consent")
  dataDeletionRequestedAt DateTime? @map("data_deletion_requested_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  addresses       CustomerAddress[]
  orders          Order[]
  reviews         Review[]

  @@map("customers")
}

model CustomerAddress {
  id             String   @id @default(uuid()) @db.Uuid
  customerId     String   @map("customer_id") @db.Uuid
  nickname       String
  street         String
  number         String
  neighborhood   String
  city           String
  state          String   @default("PR")
  zipCode        String   @map("zip_code")
  complement     String?
  referencePoint String?  @map("reference_point")
  latitude       Float?
  longitude      Float?
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")

  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

model Deliverer {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash")
  phone         String   @unique
  vehicleType   String   @map("vehicle_type")
  licensePlate  String?  @map("license_plate")
  isActive      Boolean  @default(true) @map("is_active")
  isAvailable   Boolean  @default(false) @map("is_available")
  isActiveToday Boolean  @default(false) @map("is_active_today")
  deliveryStatus DelivererWorkStatus @default(AVAILABLE) @map("delivery_status")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  orders        Order[]
  deliveryAssignments DeliveryAssignment[]

  @@map("deliverers")
}

model Product {
  id            String               @id @default(uuid()) @db.Uuid
  merchantId    String               @map("merchant_id") @db.Uuid
  name          String
  description   String
  price         Float
  category      String
  image         String?
  isAvailable   Boolean              @default(true) @map("is_available")
  stockQuantity Int                  @default(99) @map("stock_quantity")
  isPaused      Boolean              @default(false) @map("is_paused")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  merchant      Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  optionGroups  ProductOptionGroup[]
  orderItems    OrderItem[]

  @@index([merchantId, isAvailable, isPaused])
  @@index([merchantId, category])
  @@map("products")
}

model ProductOptionGroup {
  id         String          @id @default(uuid()) @db.Uuid
  productId  String          @map("product_id") @db.Uuid
  name       String
  required   Boolean         @default(false)
  minSelect  Int             @default(0) @map("min_select")
  maxSelect  Int             @default(1) @map("max_select")

  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  options    ProductOption[]

  @@map("product_option_groups")
}

model ProductOption {
  id      String             @id @default(uuid()) @db.Uuid
  groupId String             @map("group_id") @db.Uuid
  name    String
  price   Float              @default(0.00)

  group   ProductOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("product_options")
}

model Order {
  id                 String               @id @default(uuid()) @db.Uuid
  customerId         String               @map("customer_id") @db.Uuid
  merchantId         String               @map("merchant_id") @db.Uuid
  delivererId        String?              @map("deliverer_id") @db.Uuid
  subtotal           Float
  commission         Float
  deliveryFee        Float                @default(5.00) @map("delivery_fee")
  total              Float
  status             OrderStatus          @default(PENDING)
  paymentMethod      String               @map("payment_method")
  deliveryStreet     String               @map("delivery_street")
  deliveryNumber     String               @map("delivery_number")
  deliveryNeighborhood String             @map("delivery_neighborhood")
  deliveryCity       String               @map("delivery_city")
  deliveryState      String               @map("delivery_state")
  deliveryZip        String               @map("delivery_zip")
  deliveryComplement String?              @map("delivery_complement")
  deliveryReference  String?              @map("delivery_reference")
  mpPaymentId        String?              @map("mp_payment_id")
  paymentStatus      PaymentStatus?       @default(PENDING) @map("payment_status")
  pixQrCode          String?              @map("pix_qr_code")
  pixCopyAndPaste    String?              @map("pix_copy_and_paste")
  couponId           String?              @map("coupon_id") @db.Uuid
  delivererStatus    DelivererResponseStatus? @map("deliverer_status")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  customer           Customer             @relation(fields: [customerId], references: [id])
  merchant           Merchant             @relation(fields: [merchantId], references: [id])
  deliverer          Deliverer?           @relation(fields: [delivererId], references: [id])
  statusHistory      OrderStatusHistory[]
  items              OrderItem[]
  coupon             Coupon?              @relation(fields: [couponId], references: [id])
  review             Review?
  paymentWebhookEvents PaymentWebhookEvent[]
  paymentRefunds     PaymentRefund[]
  deliveryAssignments DeliveryAssignment[]
  auditLogs          AuditLog[]

  @@unique([mpPaymentId])
  @@index([customerId, createdAt])
  @@index([merchantId, status, createdAt])
  @@index([delivererId, status])
  @@index([paymentStatus, createdAt])
  @@map("orders")
}

model OrderStatusHistory {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  status    OrderStatus
  changedAt DateTime @default(now()) @map("changed_at")

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, changedAt])
  @@map("order_status_history")
}

model OrderItem {
  id        String             @id @default(uuid()) @db.Uuid
  orderId   String             @map("order_id") @db.Uuid
  productId String             @map("product_id") @db.Uuid
  name      String
  price     Float
  quantity  Int
  notes     String?

  order     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product            @relation(fields: [productId], references: [id])
  options   OrderItemOption[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderItemOption {
  id          String    @id @default(uuid()) @db.Uuid
  orderItemId String    @map("order_item_id") @db.Uuid
  groupName   String    @map("group_name")
  optionName  String    @map("option_name")
  price       Float

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_item_options")
}

model Notification {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  userType     String    @map("user_type")
  type         String
  target       String
  content      String
  status       NotificationStatus @default(QUEUED)
  errorMessage String?   @map("error_message")
  attempts     Int       @default(0)
  providerMessageId String? @map("provider_message_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  sentAt       DateTime? @map("sent_at")
  lastAttemptAt DateTime? @map("last_attempt_at")

  @@index([status, createdAt])
  @@index([userId, userType, status, createdAt])
  @@map("notifications")
}

model PaymentWebhookEvent {
  id          String    @id @default(uuid()) @db.Uuid
  provider    String
  eventId     String    @map("event_id")
  eventType   String?   @map("event_type")
  action      String?
  resourceId  String?   @map("resource_id")
  orderId     String?   @map("order_id") @db.Uuid
  status      PaymentWebhookEventStatus @default(PROCESSING)
  payload     Json?
  errorMessage String?  @map("error_message")
  receivedAt  DateTime  @default(now()) @map("received_at")
  processedAt DateTime? @map("processed_at")

  order       Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([status, receivedAt])
  @@index([resourceId])
  @@map("payment_webhook_events")
}

model PaymentRefund {
  id          String   @id @default(uuid()) @db.Uuid
  provider    String
  orderId     String   @map("order_id") @db.Uuid
  paymentId   String   @map("payment_id")
  refundId    String?  @map("refund_id")
  amount      Float?
  status      PaymentRefundStatus @default(PENDING)
  reason      String?
  errorMessage String? @map("error_message")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status, updatedAt])
  @@index([paymentId])
  @@index([provider, paymentId, status])
  @@index([provider, refundId])
  @@map("payment_refunds")
}

model Promotion {
  id                 String   @id @default(uuid()) @db.Uuid
  merchantId         String   @map("merchant_id") @db.Uuid
  discountPercentage Float    @map("discount_percentage")
  expirationDate     DateTime @map("expiration_date")
  categoryApplicable String?  @map("category_applicable")
  productIds         String[] @map("product_ids")
  createdAt          DateTime @default(now()) @map("created_at")

  merchant           Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, expirationDate])
  @@map("promotions")
}

model Banner {
  id        String   @id @default(uuid()) @db.Uuid
  imageUrl  String   @map("image_url")
  title     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banners")
}

model SystemConfig {
  id                       String   @id @default(uuid()) @db.Uuid
  defaultSubscriptionPrice Float    @default(125.00) @map("default_subscription_price")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model SystemAdmin {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  passwordResetToken  String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("system_admins")
}

model DeliveryAssignment {
  id          String                   @id @default(uuid()) @db.Uuid
  orderId     String                   @map("order_id") @db.Uuid
  delivererId String                   @map("deliverer_id") @db.Uuid
  status      DeliveryAssignmentStatus @default(PENDING)
  attempt     Int                      @default(1)
  sentAt      DateTime?                @map("sent_at")
  respondedAt DateTime?                @map("responded_at")
  expiresAt   DateTime?                @map("expires_at")
  createdAt   DateTime                 @default(now()) @map("created_at")

  order       Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliverer   Deliverer                @relation(fields: [delivererId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([delivererId])
  @@index([orderId, status, createdAt])
  @@index([delivererId, status, createdAt])
  @@unique([orderId, delivererId, attempt])
  @@map("delivery_assignments")
}

model AuditLog {
  id          String         @id @default(uuid()) @db.Uuid
  actorType   AuditActorType @map("actor_type")
  actorId     String?        @map("actor_id") @db.Uuid
  action      String
  entityType  String         @map("entity_type")
  entityId    String?        @map("entity_id") @db.Uuid
  orderId     String?        @map("order_id") @db.Uuid
  merchantId  String?        @map("merchant_id") @db.Uuid
  metadata    Json?
  ipAddress   String?        @map("ip_address")
  userAgent   String?        @map("user_agent")
  createdAt   DateTime       @default(now()) @map("created_at")

  order       Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  merchant    Merchant?      @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([orderId])
  @@index([merchantId])
  @@index([actorType, actorId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model WhatsAppTemplate {
  id          String               @id @default(uuid()) @db.Uuid
  key         WhatsAppTemplateType @unique
  locale      String               @default("pt-BR")
  body        String
  isActive    Boolean              @default(true) @map("is_active")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@map("whatsapp_templates")
}

model Review {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @unique @map("order_id") @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  merchantId  String   @map("merchant_id") @db.Uuid
  rating      Int
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Coupon {
  id                 String    @id @default(uuid()) @db.Uuid
  code               String    @unique
  discountType       CouponDiscountType @default(PERCENTAGE)
  discountValue      Float     @map("discount_value")
  minOrderValue      Float?    @map("min_order_value")
  expirationDate     DateTime  @map("expiration_date")
  isActive           Boolean   @default(true) @map("is_active")
  merchantId         String?   @map("merchant_id") @db.Uuid
  maxUses            Int?      @map("max_uses")
  usedCount          Int       @default(0) @map("used_count")
  createdAt          DateTime  @default(now()) @map("created_at")

  merchant           Merchant? @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  orders             Order[]

  @@index([merchantId, isActive, expirationDate])
  @@map("coupons")
}

model UserCouponUsage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  couponId  String   @map("coupon_id") @db.Uuid
  usedAt    DateTime @default(now()) @map("used_at")

  @@unique([userId, couponId])
  @@map("user_coupon_usages")
}
